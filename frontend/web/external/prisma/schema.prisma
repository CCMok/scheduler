generator client {
  provider = "prisma-client-js"
  output   = "../prisma-generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique
  enum  Int    @unique
  users User[]

  @@map("role")
}

model RoleAudit {
  auditId        Int      @id @default(autoincrement()) @map("audit_id")
  auditTimestamp DateTime @default(now()) @map("audit_timestamp") @db.Timestamptz(3)
  auditAction    String   @map("audit_action")
  id             Int?
  name           String?
  enum           Int?

  @@map("role_audit")
}

model User {
  id                     Int                @id @default(autoincrement())
  email                  String             @unique
  password               String
  name                   String?
  roleId                 Int                @map("role_id")
  isEmailVerified        Boolean            @default(false) @map("is_email_verified")
  role                   Role               @relation(fields: [roleId], references: [id])
  userOrganizations      UserOrganization[]
  createdRosterHistories RosterHistory[]    @relation("CreatedBy")
  updatedRosterHistories RosterHistory[]    @relation("UpdatedBy")

  @@index([roleId])
  @@map("user")
}

model UserAudit {
  auditId         Int      @id @default(autoincrement()) @map("audit_id")
  auditTimestamp  DateTime @default(now()) @map("audit_timestamp") @db.Timestamptz(3)
  auditAction     String   @map("audit_action")
  id              Int?
  email           String?
  password        String?
  name            String?
  roleId          Int?     @map("role_id")
  isEmailVerified Boolean? @map("is_email_verified")

  @@map("user_audit")
}

model Organization {
  id                Int                @id @default(autoincrement())
  name              String             @unique
  maxHistoryCount   Int?               @map("max_history_count")
  userOrganizations UserOrganization[]
  departments       Department[]

  @@map("organization")
}

model OrganizationAudit {
  auditId         Int      @id @default(autoincrement()) @map("audit_id")
  auditTimestamp  DateTime @default(now()) @map("audit_timestamp") @db.Timestamptz(3)
  auditAction     String   @map("audit_action")
  id              Int?
  name            String?
  maxHistoryCount Int?     @map("max_history_count")

  @@map("organization_audit")
}

model UserOrganization {
  id             Int          @id @default(autoincrement())
  userId         Int          @map("user_id")
  organizationId Int          @map("organization_id")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
  @@map("user_organization")
}

model UserOrganizationAudit {
  auditId        Int      @id @default(autoincrement()) @map("audit_id")
  auditTimestamp DateTime @default(now()) @map("audit_timestamp") @db.Timestamptz(3)
  auditAction    String   @map("audit_action")
  id             Int?
  userId         Int?     @map("user_id")
  organizationId Int?     @map("organization_id")

  @@map("user_organization_audit")
}

model Department {
  id                Int                @id @default(autoincrement())
  organizationId    Int                @map("organization_id")
  name              String
  posts             Post[]
  workers           Worker[]
  postConstraints   PostConstraint[]
  workerConstraints WorkerConstraint[]
  rosterHistories   RosterHistory[]
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("department")
}

model DepartmentAudit {
  auditId        Int      @id @default(autoincrement()) @map("audit_id")
  auditTimestamp DateTime @default(now()) @map("audit_timestamp") @db.Timestamptz(3)
  auditAction    String   @map("audit_action")
  id             Int?
  organizationId Int?     @map("organization_id")
  name           String?

  @@map("department_audit")
}

model Post {
  id                                Int                                @id @default(autoincrement())
  departmentId                      Int                                @map("department_id")
  name                              String
  isDeleted                         Boolean                            @default(false) @map("is_deleted")
  displayPosition                   Int                                @default(0) @map("display_position")
  department                        Department                         @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  postWorkers                       PostWorker[]
  postConstraintPosts               PostConstraintPost[]
  rosterHistoryScheduleArrangements RosterHistoryScheduleArrangement[]

  // Unique index defined at migration 20250812063939
  @@index([departmentId])
  @@map("post")
}

model PostAudit {
  auditId         Int      @id @default(autoincrement()) @map("audit_id")
  auditTimestamp  DateTime @default(now()) @map("audit_timestamp") @db.Timestamptz(3)
  auditAction     String   @map("audit_action")
  id              Int?
  departmentId    Int?     @map("department_id")
  name            String?
  isDeleted       Boolean? @map("is_deleted")
  displayPosition Int?     @map("display_position")

  @@map("post_audit")
}

model Worker {
  id                                Int                                @id @default(autoincrement())
  departmentId                      Int                                @map("department_id")
  name                              String
  isDeleted                         Boolean                            @default(false) @map("is_deleted")
  department                        Department                         @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  postWorkers                       PostWorker[]
  workerConstraintWorkers           WorkerConstraintWorker[]
  rosterHistoryScheduleArrangements RosterHistoryScheduleArrangement[]
  rosterHistoryOffWorkers           RosterHistoryOffWorker[]

  // Unique index defined at migration 20250812063939
  @@index([departmentId])
  @@map("worker")
}

model WorkerAudit {
  auditId        Int      @id @default(autoincrement()) @map("audit_id")
  auditTimestamp DateTime @default(now()) @map("audit_timestamp") @db.Timestamptz(3)
  auditAction    String   @map("audit_action")
  id             Int?
  departmentId   Int?     @map("department_id")
  name           String?
  isDeleted      Boolean? @map("is_deleted")

  @@map("worker_audit")
}

model PostWorker {
  id       Int    @id @default(autoincrement())
  postId   Int    @map("post_id")
  workerId Int    @map("worker_id")
  post     Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  worker   Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([postId, workerId])
  @@index([postId])
  @@index([workerId])
  @@map("post_worker")
}

model PostWorkerAudit {
  auditId        Int      @id @default(autoincrement()) @map("audit_id")
  auditTimestamp DateTime @default(now()) @map("audit_timestamp") @db.Timestamptz(3)
  auditAction    String   @map("audit_action")
  id             Int?
  postId         Int?     @map("post_id")
  workerId       Int?     @map("worker_id")

  @@map("post_worker_audit")
}

model PostConstraintType {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  enum            Int              @unique
  postConstraints PostConstraint[]

  @@map("post_constraint_type")
}

model PostConstraintTypeAudit {
  auditId        Int      @id @default(autoincrement()) @map("audit_id")
  auditTimestamp DateTime @default(now()) @map("audit_timestamp") @db.Timestamptz(3)
  auditAction    String   @map("audit_action")
  id             Int?
  name           String?
  enum           Int?

  @@map("post_constraint_type_audit")
}

model PostConstraint {
  id                   Int                  @id @default(autoincrement())
  departmentId         Int                  @map("department_id")
  postConstraintTypeId Int                  @map("post_constraint_type_id")
  weighting            Decimal
  department           Department           @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  postConstraintType   PostConstraintType   @relation(fields: [postConstraintTypeId], references: [id])
  postConstraintPosts  PostConstraintPost[]

  @@index([departmentId])
  @@index([postConstraintTypeId])
  @@map("post_constraint")
}

model PostConstraintAudit {
  auditId              Int      @id @default(autoincrement()) @map("audit_id")
  auditTimestamp       DateTime @default(now()) @map("audit_timestamp") @db.Timestamptz(3)
  auditAction          String   @map("audit_action")
  id                   Int?
  departmentId         Int?     @map("department_id")
  postConstraintTypeId Int?     @map("post_constraint_type_id")
  weighting            Decimal?

  @@map("post_constraint_audit")
}

model PostConstraintPost {
  id               Int            @id @default(autoincrement())
  postConstraintId Int            @map("post_constraint_id")
  postId           Int            @map("post_id")
  postConstraint   PostConstraint @relation(fields: [postConstraintId], references: [id], onDelete: Cascade)
  post             Post           @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postConstraintId, postId])
  @@index([postConstraintId])
  @@index([postId])
  @@map("post_constraint_post")
}

model PostConstraintPostAudit {
  auditId          Int      @id @default(autoincrement()) @map("audit_id")
  auditTimestamp   DateTime @default(now()) @map("audit_timestamp") @db.Timestamptz(3)
  auditAction      String   @map("audit_action")
  id               Int?
  postConstraintId Int?     @map("post_constraint_id")
  postId           Int?     @map("post_id")

  @@map("post_constraint_post_audit")
}

model WorkerConstraintType {
  id                Int                @id @default(autoincrement())
  name              String             @unique
  enum              Int                @unique
  workerConstraints WorkerConstraint[]

  @@map("worker_constraint_type")
}

model WorkerConstraintTypeAudit {
  auditId        Int      @id @default(autoincrement()) @map("audit_id")
  auditTimestamp DateTime @default(now()) @map("audit_timestamp") @db.Timestamptz(3)
  auditAction    String   @map("audit_action")
  id             Int?
  name           String?
  enum           Int?

  @@map("worker_constraint_type_audit")
}

model WorkerConstraint {
  id                      Int                      @id @default(autoincrement())
  departmentId            Int                      @map("department_id")
  workerConstraintTypeId  Int                      @map("worker_constraint_type_id")
  weighting               Decimal
  department              Department               @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  workerConstraintType    WorkerConstraintType     @relation(fields: [workerConstraintTypeId], references: [id])
  workerConstraintWorkers WorkerConstraintWorker[]

  @@index([departmentId])
  @@index([workerConstraintTypeId])
  @@map("worker_constraint")
}

model WorkerConstraintAudit {
  auditId                Int      @id @default(autoincrement()) @map("audit_id")
  auditTimestamp         DateTime @default(now()) @map("audit_timestamp") @db.Timestamptz(3)
  auditAction            String   @map("audit_action")
  id                     Int?
  departmentId           Int?     @map("department_id")
  workerConstraintTypeId Int?     @map("worker_constraint_type_id")
  weighting              Decimal?

  @@map("worker_constraint_audit")
}

model WorkerConstraintWorker {
  id                 Int              @id @default(autoincrement())
  workerConstraintId Int              @map("worker_constraint_id")
  workerId           Int              @map("worker_id")
  workerConstraint   WorkerConstraint @relation(fields: [workerConstraintId], references: [id], onDelete: Cascade)
  worker             Worker           @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([workerConstraintId, workerId])
  @@index([workerConstraintId])
  @@index([workerId])
  @@map("worker_constraint_worker")
}

model WorkerConstraintWorkerAudit {
  auditId            Int      @id @default(autoincrement()) @map("audit_id")
  auditTimestamp     DateTime @default(now()) @map("audit_timestamp") @db.Timestamptz(3)
  auditAction        String   @map("audit_action")
  id                 Int?
  workerConstraintId Int?     @map("worker_constraint_id")
  workerId           Int?     @map("worker_id")

  @@map("worker_constraint_worker_audit")
}

model RosterHistory {
  id                      Int                      @id @default(autoincrement())
  departmentId            Int                      @map("department_id")
  createdAt               DateTime                 @default(now()) @map("created_at") @db.Timestamptz(3)
  createdByUserId         Int                      @map("created_by_user_id")
  updatedAt               DateTime?                @map("updated_at") @db.Timestamptz(3)
  updatedByUserId         Int?                     @map("updated_by_user_id")
  department              Department               @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  createdByUser           User                     @relation("CreatedBy", fields: [createdByUserId], references: [id])
  updatedByUser           User?                    @relation("UpdatedBy", fields: [updatedByUserId], references: [id])
  rosterHistorySchedules  RosterHistorySchedule[]
  rosterHistoryOffWorkers RosterHistoryOffWorker[]

  @@index([departmentId])
  @@index([createdByUserId])
  @@index([updatedByUserId])
  @@map("roster_history")
}

model RosterHistoryAudit {
  auditId         Int       @id @default(autoincrement()) @map("audit_id")
  auditTimestamp  DateTime  @default(now()) @map("audit_timestamp") @db.Timestamptz(3)
  auditAction     String    @map("audit_action")
  id              Int?
  departmentId    Int?      @map("department_id")
  createdAt       DateTime? @map("created_at") @db.Timestamptz(3)
  createdByUserId Int?      @map("created_by_user_id")
  updatedAt       DateTime? @map("updated_at") @db.Timestamptz(3)
  updatedByUserId Int?      @map("updated_by_user_id")

  @@map("roster_history_audit")
}

model RosterHistorySchedule {
  id                                Int                                @id @default(autoincrement())
  rosterHistoryId                   Int                                @map("roster_history_id")
  day                               DateTime                           @db.Timestamptz(3)
  rosterHistory                     RosterHistory                      @relation(fields: [rosterHistoryId], references: [id], onDelete: Cascade)
  rosterHistoryScheduleArrangements RosterHistoryScheduleArrangement[]

  @@index([rosterHistoryId])
  @@map("roster_history_schedule")
}

model RosterHistoryScheduleAudit {
  auditId         Int       @id @default(autoincrement()) @map("audit_id")
  auditTimestamp  DateTime  @default(now()) @map("audit_timestamp") @db.Timestamptz(3)
  auditAction     String    @map("audit_action")
  id              Int?
  rosterHistoryId Int?      @map("roster_history_id")
  day             DateTime? @db.Timestamptz(3)

  @@map("roster_history_schedule_audit")
}

model RosterHistoryScheduleArrangement {
  id                      Int                   @id @default(autoincrement())
  rosterHistoryScheduleId Int                   @map("roster_history_schedule_id")
  postId                  Int                   @map("post_id")
  workerId                Int?                  @map("worker_id")
  rosterHistorySchedule   RosterHistorySchedule @relation(fields: [rosterHistoryScheduleId], references: [id], onDelete: Cascade)
  post                    Post                  @relation(fields: [postId], references: [id], onDelete: Cascade)
  worker                  Worker?               @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([rosterHistoryScheduleId])
  @@index([postId])
  @@index([workerId])
  @@map("roster_history_schedule_arrangement")
}

model RosterHistoryScheduleArrangementAudit {
  auditId                 Int      @id @default(autoincrement()) @map("audit_id")
  auditTimestamp          DateTime @default(now()) @map("audit_timestamp") @db.Timestamptz(3)
  auditAction             String   @map("audit_action")
  id                      Int?
  rosterHistoryScheduleId Int?     @map("roster_history_schedule_id")
  postId                  Int?     @map("post_id")
  workerId                Int?     @map("worker_id")

  @@map("roster_history_schedule_arrangement_audit")
}

model RosterHistoryOffWorker {
  id                         Int                         @id @default(autoincrement())
  rosterHistoryId            Int                         @map("roster_history_id")
  workerId                   Int                         @map("worker_id")
  rosterHistory              RosterHistory               @relation(fields: [rosterHistoryId], references: [id], onDelete: Cascade)
  worker                     Worker                      @relation(fields: [workerId], references: [id], onDelete: Cascade)
  rosterHistoryOffWorkerDays RosterHistoryOffWorkerDay[]

  @@index([rosterHistoryId])
  @@index([workerId])
  @@map("roster_history_off_worker")
}

model RosterHistoryOffWorkerAudit {
  auditId         Int      @id @default(autoincrement()) @map("audit_id")
  auditTimestamp  DateTime @default(now()) @map("audit_timestamp") @db.Timestamptz(3)
  auditAction     String   @map("audit_action")
  id              Int?
  rosterHistoryId Int?     @map("roster_history_id")
  workerId        Int?     @map("worker_id")

  @@map("roster_history_off_worker_audit")
}

model RosterHistoryOffWorkerDay {
  id                       Int                    @id @default(autoincrement())
  rosterHistoryOffWorkerId Int                    @map("roster_history_off_worker_id")
  day                      DateTime               @db.Timestamptz(3)
  rosterHistoryOffWorker   RosterHistoryOffWorker @relation(fields: [rosterHistoryOffWorkerId], references: [id], onDelete: Cascade)

  @@index([rosterHistoryOffWorkerId])
  @@map("roster_history_off_worker_day")
}

model RosterHistoryOffWorkerDayAudit {
  auditId                  Int       @id @default(autoincrement()) @map("audit_id")
  auditTimestamp           DateTime  @default(now()) @map("audit_timestamp") @db.Timestamptz(3)
  auditAction              String    @map("audit_action")
  id                       Int?
  rosterHistoryOffWorkerId Int?      @map("roster_history_off_worker_id")
  day                      DateTime? @db.Timestamptz(3)

  @@map("roster_history_off_worker_day_audit")
}
