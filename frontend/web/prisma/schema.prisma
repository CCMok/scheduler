generator client {
  provider = "prisma-client-js"
  output   = "../prisma-generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                Int                @id @default(autoincrement())
  name              String             @unique
  posts             Post[]
  workers           Worker[]
  postConstraints   PostConstraint[]
  workerConstraints WorkerConstraint[]
  userTenants       UserTenant[]

  @@map("tenant")
}

model Post {
  id                  Int                  @id @default(autoincrement())
  tenantId            Int                  @map("tenant_id")
  name                String
  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  postWorkers         PostWorker[]
  postConstraintPosts PostConstraintPost[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("post")
}

model Worker {
  id                      Int                      @id @default(autoincrement())
  tenantId                Int                      @map("tenant_id")
  name                    String
  tenant                  Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  postWorkers             PostWorker[]
  workerConstraintWorkers WorkerConstraintWorker[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("worker")
}

model PostWorker {
  id       Int    @id @default(autoincrement())
  postId   Int    @map("post_id")
  workerId Int    @map("worker_id")
  post     Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  worker   Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([postId, workerId])
  @@index([postId])
  @@index([workerId])
  @@map("post_worker")
}

model PostConstraintType {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  enum            Int              @unique
  postConstraints PostConstraint[]

  @@map("post_constraint_type")
}

model PostConstraint {
  id                   Int                  @id @default(autoincrement())
  tenantId             Int                  @map("tenant_id")
  postConstraintTypeId Int                  @map("post_constraint_type_id")
  weighting            Int
  tenant               Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  postConstraintType   PostConstraintType   @relation(fields: [postConstraintTypeId], references: [id], onDelete: Cascade)
  postConstraintPosts  PostConstraintPost[]

  @@index([tenantId])
  @@index([postConstraintTypeId])
  @@map("post_constraint")
}

model PostConstraintPost {
  id               Int            @id @default(autoincrement())
  postConstraintId Int            @map("post_constraint_id")
  postId           Int            @map("post_id")
  postConstraint   PostConstraint @relation(fields: [postConstraintId], references: [id], onDelete: Cascade)
  post             Post           @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postConstraintId, postId])
  @@index([postConstraintId])
  @@index([postId])
  @@map("post_constraint_post")
}

model WorkerConstraintType {
  id                Int                @id @default(autoincrement())
  name              String             @unique
  enum              Int                @unique
  workerConstraints WorkerConstraint[]

  @@map("worker_constraint_type")
}

model WorkerConstraint {
  id                      Int                      @id @default(autoincrement())
  tenantId                Int                      @map("tenant_id")
  workerConstraintTypeId  Int                      @map("worker_constraint_type_id")
  weighting               Int
  tenant                  Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workerConstraintType    WorkerConstraintType     @relation(fields: [workerConstraintTypeId], references: [id], onDelete: Cascade)
  workerConstraintWorkers WorkerConstraintWorker[]

  @@index([tenantId])
  @@index([workerConstraintTypeId])
  @@map("worker_constraint")
}

model WorkerConstraintWorker {
  id                 Int              @id @default(autoincrement())
  workerConstraintId Int              @map("worker_constraint_id")
  workerId           Int              @map("worker_id")
  workerConstraint   WorkerConstraint @relation(fields: [workerConstraintId], references: [id], onDelete: Cascade)
  worker             Worker           @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([workerConstraintId, workerId])
  @@index([workerConstraintId])
  @@index([workerId])
  @@map("worker_constraint_worker")
}

model User {
  id          Int          @id @default(autoincrement())
  email       String       @unique
  password    String
  name        String?
  roleId      Int          @map("role_id")
  role        Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)
  userTenants UserTenant[]

  @@index([roleId])
  @@map("user")
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique
  enum  Int    @unique
  users User[]

  @@map("role")
}

model UserTenant {
  id       Int    @id @default(autoincrement())
  userId   Int    @map("user_id")
  tenantId Int    @map("tenant_id")
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([userId])
  @@index([tenantId])
  @@map("user_tenant")
}
