generator client {
  provider = "prisma-client-js"
  output   = "../prisma-generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                       Int                       @id @default(autoincrement())
  name                     String                    @unique
  posts                    Post[]
  workers                  Worker[]
  postconstraintSettings   PostConstraintSetting[]
  workerConstraintSettings WorkerConstraintSetting[]

  @@map("tenant")
}

model Post {
  id                     Int                         @id @default(autoincrement())
  tenantId               Int                         @map("tenant_id")
  name                   String
  tenant                 Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  postWorkers            PostWorker[]
  constraintSettingPosts PostConstraintSettingPost[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("post")
}

model Worker {
  id                       Int                             @id @default(autoincrement())
  tenantId                 Int                             @map("tenant_id")
  name                     String
  tenant                   Tenant                          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  postWorkers              PostWorker[]
  constraintSettingWorkers WorkerConstraintSettingWorker[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("worker")
}

model PostWorker {
  id       Int    @id @default(autoincrement())
  postId   Int    @map("post_id")
  workerId Int    @map("worker_id")
  post     Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  worker   Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([postId, workerId])
  @@index([postId])
  @@index([workerId])
  @@map("post_worker")
}

model PostConstraintType {
  id                 Int                     @id @default(autoincrement())
  name               String                  @unique
  enum               Int                     @unique
  constraintSettings PostConstraintSetting[]

  @@map("post_constraint_type")
}

model PostConstraintSetting {
  id               Int                         @id @default(autoincrement())
  tenantId         Int                         @map("tenant_id")
  constraintTypeId Int                         @map("constraint_type_id")
  weighting        Int
  tenant           Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  constraintType   PostConstraintType          @relation(fields: [constraintTypeId], references: [id], onDelete: Cascade)
  posts            PostConstraintSettingPost[]

  @@index([tenantId])
  @@index([constraintTypeId])
  @@map("post_constraint_setting")
}

model PostConstraintSettingPost {
  id                  Int                   @id @default(autoincrement())
  constraintSettingId Int                   @map("constraint_setting_id")
  postId              Int                   @map("post_id")
  constraintSetting   PostConstraintSetting @relation(fields: [constraintSettingId], references: [id], onDelete: Cascade)
  post                Post                  @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([constraintSettingId, postId])
  @@index([constraintSettingId])
  @@index([postId])
  @@map("post_constraint_setting_post")
}

model WorkerConstraintType {
  id                 Int                       @id @default(autoincrement())
  name               String                    @unique
  enum               Int                       @unique
  constraintSettings WorkerConstraintSetting[]

  @@map("worker_constraint_type")
}

model WorkerConstraintSetting {
  id               Int                             @id @default(autoincrement())
  tenantId         Int                             @map("tenant_id")
  constraintTypeId Int                             @map("constraint_type_id")
  weighting        Int
  tenant           Tenant                          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  constraintType   WorkerConstraintType            @relation(fields: [constraintTypeId], references: [id], onDelete: Cascade)
  workers          WorkerConstraintSettingWorker[]

  @@index([tenantId])
  @@index([constraintTypeId])
  @@map("worker_constraint_setting")
}

model WorkerConstraintSettingWorker {
  id                  Int                     @id @default(autoincrement())
  constraintSettingId Int                     @map("constraint_setting_id")
  workerId            Int                     @map("worker_id")
  constraintSetting   WorkerConstraintSetting @relation(fields: [constraintSettingId], references: [id], onDelete: Cascade)
  worker              Worker                  @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([constraintSettingId, workerId])
  @@index([constraintSettingId])
  @@index([workerId])
  @@map("worker_constraint_setting_worker")
}
