generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Post {
  id     Int    @id @default(autoincrement())
  tenant String
  name   String

  @@map("post")
}

model Worker {
  id     Int    @id @default(autoincrement())
  tenant String
  name   String

  @@map("worker")
}
