generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id    Int    @id
  name  String @unique
  users User[]

  @@map("role")
}

model RoleAudit {
  auditId        Int      @id @default(autoincrement()) @map("audit_id")
  auditTimestamp DateTime @default(now()) @map("audit_timestamp") @db.Timestamptz(3)
  auditAction    String   @map("audit_action")
  id             Int?
  name           String?

  @@map("role_audit")
}

model User {
  id       Int     @id @default(autoincrement())
  email    String  @unique
  password String
  name     String?
  roleId   Int     @map("role_id")
  role     Role    @relation(fields: [roleId], references: [id])
  teams    Team[]

  @@index([roleId])
  @@map("user")
}

model UserAudit {
  auditId        Int      @id @default(autoincrement()) @map("audit_id")
  auditTimestamp DateTime @default(now()) @map("audit_timestamp") @db.Timestamptz(3)
  auditAction    String   @map("audit_action")
  id             Int?
  email          String?
  password       String?
  name           String?
  roleId         Int?     @map("role_id")

  @@map("user_audit")
}

model Team {
  id                       Int              @id @default(autoincrement())
  ownerId                  Int              @map("owner_id")
  name                     String
  maxWorkerAssignPerRoster Int?             @map("max_worker_assign_per_roster")
  owner                    User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  workers                  Worker[]
  posts                    Post[]
  workerAffinities         WorkerAffinity[]
  postAffinities           PostAffinity[]
  rosters                  Roster[]

  @@unique([ownerId, name])
  @@index([ownerId])
  @@map("team")
}

model TeamAudit {
  auditId                  Int      @id @default(autoincrement()) @map("audit_id")
  auditTimestamp           DateTime @default(now()) @map("audit_timestamp") @db.Timestamptz(3)
  auditAction              String   @map("audit_action")
  id                       Int?
  ownerId                  Int?     @map("owner_id")
  name                     String?
  maxWorkerAssignPerRoster Int?     @map("max_worker_assign_per_roster")

  @@map("team_audit")
}

model Post {
  id                  Int                  @id @default(autoincrement())
  teamId              Int                  @map("team_id")
  name                String
  displayOrder        Int                  @default(0) @map("display_order")
  team                Team                 @relation(fields: [teamId], references: [id], onDelete: Cascade)
  postWorkers         PostWorker[]
  postAffinityMembers PostAffinityMember[]

  @@unique([teamId, name])
  @@index([teamId])
  @@map("post")
}

model PostAudit {
  auditId        Int      @id @default(autoincrement()) @map("audit_id")
  auditTimestamp DateTime @default(now()) @map("audit_timestamp") @db.Timestamptz(3)
  auditAction    String   @map("audit_action")
  id             Int?
  teamId         Int?     @map("team_id")
  name           String?
  displayOrder   Int?     @map("display_order")

  @@map("post_audit")
}

model Worker {
  id                    Int                    @id @default(autoincrement())
  teamId                Int                    @map("team_id")
  name                  String
  team                  Team                   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  postWorkers           PostWorker[]
  workerAffinityMembers WorkerAffinityMember[]

  @@unique([teamId, name])
  @@index([teamId])
  @@map("worker")
}

model WorkerAudit {
  auditId        Int      @id @default(autoincrement()) @map("audit_id")
  auditTimestamp DateTime @default(now()) @map("audit_timestamp") @db.Timestamptz(3)
  auditAction    String   @map("audit_action")
  id             Int?
  teamId         Int?     @map("team_id")
  name           String?

  @@map("worker_audit")
}

model PostWorker {
  id       Int    @id @default(autoincrement())
  postId   Int    @map("post_id")
  workerId Int    @map("worker_id")
  priority Int    @default(0) @map("priority")
  post     Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  worker   Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([postId, workerId])
  @@index([postId])
  @@index([workerId])
  @@map("post_worker")
}

model PostWorkerAudit {
  auditId        Int      @id @default(autoincrement()) @map("audit_id")
  auditTimestamp DateTime @default(now()) @map("audit_timestamp") @db.Timestamptz(3)
  auditAction    String   @map("audit_action")
  id             Int?
  postId         Int?     @map("post_id")
  workerId       Int?     @map("worker_id")
  priority       Int?     @map("priority")

  @@map("post_worker_audit")
}

model PostAffinity {
  id      Int                  @id @default(autoincrement())
  teamId  Int                  @map("team_id")
  team    Team                 @relation(fields: [teamId], references: [id], onDelete: Cascade)
  members PostAffinityMember[]

  @@index([teamId])
  @@map("post_affinity")
}

model PostAffinityAudit {
  auditId        Int      @id @default(autoincrement()) @map("audit_id")
  auditTimestamp DateTime @default(now()) @map("audit_timestamp") @db.Timestamptz(3)
  auditAction    String   @map("audit_action")
  id             Int?
  teamId         Int?     @map("team_id")

  @@map("post_affinity_audit")
}

model PostAffinityMember {
  id             Int          @id @default(autoincrement())
  postAffinityId Int          @map("post_affinity_id")
  postId         Int          @map("post_id")
  postAffinity   PostAffinity @relation(fields: [postAffinityId], references: [id], onDelete: Cascade)
  post           Post         @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postAffinityId, postId])
  @@index([postAffinityId])
  @@index([postId])
  @@map("post_affinity_member")
}

model PostAffinityMemberAudit {
  auditId        Int      @id @default(autoincrement()) @map("audit_id")
  auditTimestamp DateTime @default(now()) @map("audit_timestamp") @db.Timestamptz(3)
  auditAction    String   @map("audit_action")
  id             Int?
  postAffinityId Int?     @map("post_affinity_id")
  postId         Int?     @map("post_id")

  @@map("post_affinity_member_audit")
}

model WorkerAffinity {
  id      Int                    @id @default(autoincrement())
  teamId  Int                    @map("team_id")
  team    Team                   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  members WorkerAffinityMember[]

  @@index([teamId])
  @@map("worker_affinity")
}

model WorkerAffinityAudit {
  auditId        Int      @id @default(autoincrement()) @map("audit_id")
  auditTimestamp DateTime @default(now()) @map("audit_timestamp") @db.Timestamptz(3)
  auditAction    String   @map("audit_action")
  id             Int?
  teamId         Int?     @map("team_id")

  @@map("worker_affinity_audit")
}

model WorkerAffinityMember {
  id               Int            @id @default(autoincrement())
  workerAffinityId Int            @map("worker_affinity_id")
  workerId         Int            @map("worker_id")
  workerAffinity   WorkerAffinity @relation(fields: [workerAffinityId], references: [id], onDelete: Cascade)
  worker           Worker         @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([workerAffinityId, workerId])
  @@index([workerAffinityId])
  @@index([workerId])
  @@map("worker_affinity_member")
}

model WorkerAffinityMemberAudit {
  auditId          Int      @id @default(autoincrement()) @map("audit_id")
  auditTimestamp   DateTime @default(now()) @map("audit_timestamp") @db.Timestamptz(3)
  auditAction      String   @map("audit_action")
  id               Int?
  workerAffinityId Int?     @map("worker_affinity_id")
  workerId         Int?     @map("worker_id")

  @@map("worker_affinity_member_audit")
}

model Roster {
  id               Int               @id @default(autoincrement())
  teamId           Int               @map("team_id")
  name             String            @map("name")
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  team             Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  timeslots        RosterTimeslot[]

  @@unique([teamId, name])
  @@index([teamId])
  @@map("roster")
}

model RosterAudit {
  auditId        Int       @id @default(autoincrement()) @map("audit_id")
  auditTimestamp DateTime  @default(now()) @map("audit_timestamp") @db.Timestamptz(3)
  auditAction    String    @map("audit_action")
  id             Int?
  teamId         Int?      @map("team_id")
  name           String?   @map("name")
  createdAt      DateTime? @map("created_at") @db.Timestamptz(3)

  @@map("roster_audit")
}

model RosterTimeslot {
  id                 Int                        @id @default(autoincrement())
  rosterId           Int                        @map("roster_id")
  timeslot           String                     @map("timeslot")
  roster             Roster                     @relation(fields: [rosterId], references: [id], onDelete: Cascade)
  assignments        RosterTimeslotAssignment[]
  rosterTimeslotOffs RosterTimeslotOff[]

  @@unique([rosterId, timeslot])
  @@index([rosterId])
  @@map("roster_timeslot")
}

model RosterTimeslotAudit {
  auditId        Int      @id @default(autoincrement()) @map("audit_id")
  auditTimestamp DateTime @default(now()) @map("audit_timestamp") @db.Timestamptz(3)
  auditAction    String   @map("audit_action")
  id             Int?
  rosterId       Int?     @map("roster_id")
  timeslot       String?  @map("timeslot")

  @@map("roster_timeslot_audit")
}

model RosterTimeslotAssignment {
  id                 Int            @id @default(autoincrement())
  rosterTimeslotId   Int            @map("roster_timeslot_id")
  postId             Int            @map("post_id")
  workerId           Int?           @map("worker_id")
  fallbackPostName   String         @map("fallback_post_name")
  fallbackWorkerName String?        @map("fallback_worker_name")
  rosterTimeslot     RosterTimeslot @relation(fields: [rosterTimeslotId], references: [id], onDelete: Cascade)

  @@unique([rosterTimeslotId, postId])
  @@index([rosterTimeslotId])
  @@index([postId])
  @@index([workerId])
  @@map("roster_timeslot_assignment")
}

model RosterTimeslotAssignmentAudit {
  auditId            Int      @id @default(autoincrement()) @map("audit_id")
  auditTimestamp     DateTime @default(now()) @map("audit_timestamp") @db.Timestamptz(3)
  auditAction        String   @map("audit_action")
  id                 Int?
  rosterTimeslotId   Int?     @map("roster_timeslot_id")
  postId             Int?     @map("post_id")
  workerId           Int?     @map("worker_id")
  fallbackPostName   String?  @map("fallback_post_name")
  fallbackWorkerName String?  @map("fallback_worker_name")

  @@map("roster_timeslot_assignment_audit")
}

model RosterTimeslotOff {
  id                  Int            @id @default(autoincrement())
  rosterTimeslotOffId Int            @map("roster_timeslot_off_id")
  workerId            Int            @map("worker_id")
  fallbackWorkerName  String         @map("fallback_worker_name")
  rosterTimeslot      RosterTimeslot @relation(fields: [rosterTimeslotOffId], references: [id], onDelete: Cascade)

  @@unique([rosterTimeslotOffId, workerId])
  @@index([rosterTimeslotOffId])
  @@index([workerId])
  @@map("roster_timeslot_off")
}

model RosterTimeslotOffAudit {
  auditId             Int      @id @default(autoincrement()) @map("audit_id")
  auditTimestamp      DateTime @default(now()) @map("audit_timestamp") @db.Timestamptz(3)
  auditAction         String   @map("audit_action")
  id                  Int?
  rosterTimeslotOffId Int?     @map("roster_timeslot_off_id")
  workerId            Int?     @map("worker_id")
  fallbackWorkerName  String?  @map("fallback_worker_name")

  @@map("roster_timeslot_off_audit")
}
